# Ignore common unwanted files globally
**/.DS_Store
**/.env
**/__pycache__/
*.py[cod]
**/.conda/

#Ignore IDE files
.cursor/
.windsurf/

# ignore test files in root dir
/*.test.py

# Ignore all contents of the virtual environment directory
.venv/

# obsolete folders
memory/
knowledge/custom/
instruments/

# Handle logs directory
logs/**
!logs/**/

# Handle tmp and usr directory
tmp/**
!tmp/**/
usr/**
!usr/**/

# Handle knowledge directory

# Global rule to include .gitkeep files anywhere
!**/.gitkeep

# for browser-use
agent_history.gif

# --- SENTRA-AI CUSTOM RULES ---

# Keep planning/design docs local (FYP brainstorms, SDLC plans)
docs/planning/

# Sentra-AI runtime secrets
.env
.env.local

# NOTE: .agent/ is intentionally NOT listed here.
# It is excluded via .git/info/exclude to keep it
# accessible to AI tools (Cursor, Windsurf, etc)
# without being tracked by git.
