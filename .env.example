# Sentra-AI Environment Variables
# Copy this file to .env and fill in your values

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here

# ── Agent0 internal API key (find it in Agent0 settings > API Key) ─────────
AGENT0_API_KEY=your-agent0-api-key-here

# ── Sentra API security ────────────────────────────────────────────────────
# This key protects your Sentra API — set it to any strong random string
SENTRA_API_KEY=your-sentra-api-key-here

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=sentra
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=sentra_ai
DATABASE_URL=postgresql+asyncpg://sentra:change-me-strong-password@postgres:5432/sentra_ai
